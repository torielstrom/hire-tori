# --- Anthropic (the vision brain) ---
ANTHROPIC_API_KEY=sk-ant-...
# Vision-capable Claude model. Sonnet = good accuracy/cost; Haiku = cheaper.
CLAUDE_MODEL=claude-sonnet-4-6

# --- PostHog (AI observability — use your real ChaseDex project) ---
# This is the public ChaseDex project key already in chasedex/src/config/index.ts.
POSTHOG_API_KEY=phc_VyxolBjFW9QqiA1IMSSpmoWKiIvsGCPHkuSdxxQ5ccm
POSTHOG_HOST=https://us.i.posthog.com

# --- Eval data source ---
# "r2" = read your real Cloudflare dataset (default). "local" = read from disk.
DATA_SOURCE=r2

# --- Cloudflare R2 (your tcg-lister-training bucket) ---
# No token needed: reads via your existing `wrangler` login (the same OAuth that
# uploaded the data). Just confirm you're logged in: `npx wrangler whoami`.
R2_TRAINING_BUCKET=tcg-lister-training

# --- Local fallback (only used when DATA_SOURCE=local) ---
TCG_LISTER_DIR=/Users/torielstrom/Pokemon Projects/tcg-lister
TRAINING_IMAGES_DIR=/Users/torielstrom/Desktop/data/training/images

# How many labeled cards to evaluate per class (normal/holo/reverse). Controls $ spend.
EVAL_PER_CLASS=15
# Parallel classifications (keep modest for rate limits + cost).
EVAL_CONCURRENCY=4
