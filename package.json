{
  "name": "chasedex-finish-classifier",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Vision-LLM that reads a Pokemon card's finish (normal/holo/reverse), instrumented end-to-end with PostHog AI observability + evaluated against real labels.",
  "scripts": {
    "classify": "tsx src/classify-one.ts",
    "eval": "tsx src/eval.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "@posthog/ai": "^4.0.0",
    "better-sqlite3": "^11.5.0",
    "dotenv": "^16.4.0",
    "posthog-node": "^4.10.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  },
  "overrides": {
    "@anthropic-ai/sdk": "$@anthropic-ai/sdk"
  }
}
